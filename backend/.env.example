# PostgreSQL接続文字列。ローカル開発ではRenderのPostgres(External Database URL)を
# そのまま指定するか、自前のローカルPostgresを用意して指定する。
DATABASE_URL="postgresql://user:password@localhost:5432/kakeibo?schema=public"

PORT=4000

# GEMINI_API_KEY: レシートOCR・バーコード価格予測・AI貯金コーチング機能で使用。
# 未設定の場合はモック応答にフォールバックする。
GEMINI_API_KEY="MY_GEMINI_API_KEY"
