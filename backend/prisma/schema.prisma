// 多機能家計簿アプリ - Prisma Schema
// 設計仕様書 セクション3のデータモデルを反映

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // デフォルトはSQLite（ローカル開発向け）。本番でPostgreSQLに切り替える場合は
  // provider = "postgresql" とし、DATABASE_URLを接続文字列に変更する。
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 収支の種別（支出 / 収入 / NISA積立）と定期支払いの周期は、
// SQLiteコネクタがネイティブenumをサポートしないためString型で保持する。
// 値は "EXPENSE" | "INCOME" | "NISA"、"MONTHLY" | "YEARLY" のいずれかとし、
// 妥当性はアプリケーション層(zod, src/common/enums.ts)で検証する。
// PostgreSQLに切り替える際はネイティブenumへの移行を検討可能。

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String?
  groupId       String?
  group         Group?         @relation(fields: [groupId], references: [id])
  transactions  Transaction[]
  subscriptions Subscription[]
  savingGoals   SavingGoal[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Group {
  id            String         @id @default(cuid())
  name          String
  users         User[]
  transactions  Transaction[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Transaction {
  id              String           @id @default(cuid())
  amount          Int
  date            DateTime
  type            String // "EXPENSE" | "INCOME" | "NISA" (src/common/enums.ts参照)
  memo            String?
  categoryId      String
  category        Category         @relation(fields: [categoryId], references: [id])
  paymentMethodId String
  paymentMethod   PaymentMethod    @relation(fields: [paymentMethodId], references: [id])
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  groupId         String?
  group           Group?           @relation(fields: [groupId], references: [id])
  tags            TransactionTag[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([groupId])
  @@index([date])
  @@index([categoryId])
}

model Category {
  id           String        @id @default(cuid())
  name         String        @unique
  color        String?
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}

model PaymentMethod {
  id           String        @id @default(cuid())
  name         String        @unique
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}

model Subscription {
  id              String             @id @default(cuid())
  name            String
  amount          Int
  period          String // "MONTHLY" | "YEARLY" (src/common/enums.ts参照)
  categoryId      String?
  paymentMethodId String?
  userId          String
  user            User               @relation(fields: [userId], references: [id])
  nextPaymentDate DateTime
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model SavingGoal {
  id                String   @id @default(cuid())
  title             String
  targetAmount      Int
  deadline          DateTime
  nisaMonthlyAmount Int      @default(0)
  achievedAmount    Int      @default(0)
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Tag {
  id           String           @id @default(cuid())
  name         String           @unique
  transactions TransactionTag[]
}

// Transaction <-> Tag の多対多中間テーブル
model TransactionTag {
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tagId         String
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
}
